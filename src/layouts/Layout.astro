---
import "../styles/global.css";
import Header from "../components/header.astro";

interface Props {
	title?: string;
}
const { title } = Astro.props;
const title_f = "rhpidfyre.io" + (title ? ` | ${title}` : "");
---

<!doctype html>
<html
	lang="en"
	class="scheme-light-dark selection:bg-black selection:text-white dark:selection:bg-white dark:selection:text-black"
>
	<head>
		<meta charset="utf-8" />
		<meta name="viewport" content="width=device-width" />
		<meta name="generator" content={Astro.generator} />
		<meta property="og:title" content={title_f} />
		<meta property="og:url" content="https://rhpidfyre.io" />
		<meta property="og:type" content="website" />
		<meta name="theme-color" content="#000000" />
		<title>{title_f}</title>
	</head>
	<body class="dark:bg-black m-0 flex flex-col items-center h-screen">
		{title && <Header>{title}</Header>}
		<slot />
	</body>
</html>
