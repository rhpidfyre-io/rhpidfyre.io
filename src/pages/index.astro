---
import Layout from "../layouts/Layout.astro";
import Links from "../layouts/Links.astro";
import Link from "../components/button/Link.astro";
import GitHub from "../assets/github.svg";
import { Mail } from "@lucide/astro";
---

<Layout>
	<Links>
		<Link to="/projects">Projects</Link>
		<Link to="/services">Services</Link>
		<span
			class="h-px w-[120%] dark:bg-[#333333] bg-[#808080] opacity-50 block mt-3"
		></span>
		<div
			class="[&>a]:opacity-50 [&>a]:hover:opacity-100 [&>a]:transition-opacity flex justify-evenly items-center w-full"
		>
			<a href="mailto:brandon@rhpidfyre.io">
				<Mail />
			</a>
			<a href="https://github.com/unixtensor">
				<!-- https://icons.getbootstrap.com/icons/github/ -->
				<GitHub class="size-5" />
			</a>
		</div>
	</Links>
</Layout>
